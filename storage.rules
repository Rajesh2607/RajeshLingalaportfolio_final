rules_version = '2';

service firebase.storage {
  match /b/{bucket}/o {
    
    // Security functions
    function isAuthenticated() {
      return request.auth != null;
    }

    function isAdminByUid() {
      return isAuthenticated() &&
             firestore.exists(/databases/(default)/documents/admins/$(request.auth.uid));
    }

    function isAdminByMainEmail() {
      return isAuthenticated() &&
             firestore.exists(/databases/(default)/documents/admins/main) &&
             firestore.get(/databases/(default)/documents/admins/main).data.email == request.auth.token.email;
    }

    // Existing legacy admin document currently present in this project.
    function isAdminByLegacyEmailDoc() {
      return isAuthenticated() &&
             firestore.exists(/databases/(default)/documents/admins/h423cObkVbSra5wB0HmC) &&
             firestore.get(/databases/(default)/documents/admins/h423cObkVbSra5wB0HmC).data.email == request.auth.token.email;
    }

    // UID-based admin authorization.
    function isAdmin() {
      return isAdminByUid() || isAdminByMainEmail() || isAdminByLegacyEmailDoc();
    }

    // Public image folders - allow read for all, write only for admins
    match /public/{allPaths=**} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // Admin uploads - only authenticated admins can write/read
    match /admin/{allPaths=**} {
      allow read, write: if isAdmin();
    }

    // User uploads - authenticated users can upload to their own folder
    match /users/{userId}/{allPaths=**} {
      allow read: if isAuthenticated() || true; // Allow public read for public content
      allow write: if request.auth.uid == userId || isAdmin();
    }

    // Projects media folder - only admins can write
    match /projects/{allPaths=**} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // Project media folder used by admin dashboard
    match /project_media/{allPaths=**} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // Blogs media folder - only admins can write
    match /blogs/{allPaths=**} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // Blog image folder used by AdminBlogManager
    match /BLOG_IMAGES/{allPaths=**} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // Story and hero images used by StoryManager
    match /hero-images/{allPaths=**} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // Certificates image uploads
    match /certificates/{allPaths=**} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // Education image uploads
    match /education/{allPaths=**} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // About/profile image uploads
    match /profile/{allPaths=**} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // Experience logo uploads
    match /experience-logos/{allPaths=**} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // Who I Am section image uploads
    match /whoAbout/{allPaths=**} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // Deny everything else by default
    match /{allPaths=**} {
      allow read, write: if false;
    }
  }
}
