rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    function isSignedIn() {
      return request.auth != null;
    }

    function isAdminByUid() {
      return isSignedIn() &&
             exists(/databases/$(database)/documents/admins/$(request.auth.uid));
    }

    function isAdminByMainEmail() {
      return isSignedIn() &&
             exists(/databases/$(database)/documents/admins/main) &&
             get(/databases/$(database)/documents/admins/main).data.email == request.auth.token.email;
    }

    // Existing legacy admin document currently present in this project.
    function isAdminByLegacyEmailDoc() {
      return isSignedIn() &&
             exists(/databases/$(database)/documents/admins/h423cObkVbSra5wB0HmC) &&
             get(/databases/$(database)/documents/admins/h423cObkVbSra5wB0HmC).data.email == request.auth.token.email;
    }

    // UID-based admin authorization.
    function isAdmin() {
      return isAdminByUid() || isAdminByMainEmail() || isAdminByLegacyEmailDoc();
    }

    // Admin registry documents (typically keyed by uid).
    match /admins/{adminId} {
      // Allow reads for:
      // - the user's own admin document (request.auth.uid == adminId)
      // - special lookup documents used by the rules ('main' and the legacy id)
      // - or full admin (isAdmin())
      allow read: if ( (isSignedIn() && (request.auth.uid == adminId || adminId == 'main' || adminId == 'h423cObkVbSra5wB0HmC')) || isAdmin() );

      // Updates and deletes require full admin rights.
      allow write: if isAdmin();
    }

    // Public-read content, admin-write
    match /projects/{projectId} {
      allow read: if true;
      allow create, update, delete: if isAdmin();
    }

    match /blogs/{blogId} {
      allow read: if true;
      allow create, update, delete: if isAdmin();
    }

    match /certificates/{certificateId} {
      allow read: if true;
      allow create, update, delete: if isAdmin();
    }

    match /achievements/{achievementId} {
      allow read: if true;
      allow create, update, delete: if isAdmin();
    }

    match /educations/{educationId} {
      allow read: if true;
      allow create, update, delete: if isAdmin();
    }

    match /experiences/{experienceId} {
      allow read: if true;
      allow create, update, delete: if isAdmin();
    }

    match /skills/{skillId} {
      allow read: if true;
      allow create, update, delete: if isAdmin();
    }

    match /socialLinks/{linkId} {
      allow read: if true;
      allow create, update, delete: if isAdmin();
    }

    match /socialmedia/{documentId} {
      allow read: if true;
      allow create, update, delete: if isAdmin();
    }

    match /hero/{documentId} {
      allow read: if true;
      allow create, update, delete: if isAdmin();
    }

    match /story/{documentId} {
      allow read: if true;
      allow create, update, delete: if isAdmin();
    }

    match /whoAboutSections/{sectionId} {
      allow read: if true;
      allow create, update, delete: if isAdmin();
    }

    match /content/{documentId} {
      allow read: if true;
      allow create, update, delete: if isAdmin();
    }

    // Public can submit contact form; only admins can read/manage
    match /contactSubmissions/{submissionId} {
      allow create: if true;
      allow read, update, delete: if isAdmin();
    }

    // Default deny
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
