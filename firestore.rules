rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    function isSignedIn() {
      return request.auth != null;
    }

    // Primary admin model: admins/{uid}
    function isAdminByUid() {
      return isSignedIn() &&
             exists(/databases/$(database)/documents/admins/$(request.auth.uid));
    }

    // Legacy admin model fallback: admins/config { emails: [...] }
    function isAdminByEmailConfig() {
      return isSignedIn() &&
             exists(/databases/$(database)/documents/admins/config) &&
             get(/databases/$(database)/documents/admins/config).data.emails.hasAny([request.auth.token.email]);
    }

    function isAdmin() {
      return isAdminByUid() || isAdminByEmailConfig();
    }

    // Admin email config used for login bootstrap fallback.
    match /admins/config {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }

    // Admin registry documents (typically keyed by uid).
    match /admins/{adminId} {
      allow read: if (isSignedIn() && request.auth.uid == adminId) || isAdmin();
      allow write: if isAdmin();
    }

    // Public-read content, admin-write
    match /projects/{projectId} {
      allow read: if true;
      allow create, update, delete: if isAdmin();
    }

    match /blogs/{blogId} {
      allow read: if true;
      allow create, update, delete: if isAdmin();
    }

    match /certificates/{certificateId} {
      allow read: if true;
      allow create, update, delete: if isAdmin();
    }

    match /achievements/{achievementId} {
      allow read: if true;
      allow create, update, delete: if isAdmin();
    }

    match /educations/{educationId} {
      allow read: if true;
      allow create, update, delete: if isAdmin();
    }

    match /experiences/{experienceId} {
      allow read: if true;
      allow create, update, delete: if isAdmin();
    }

    match /skills/{skillId} {
      allow read: if true;
      allow create, update, delete: if isAdmin();
    }

    match /socialLinks/{linkId} {
      allow read: if true;
      allow create, update, delete: if isAdmin();
    }

    match /socialmedia/{documentId} {
      allow read: if true;
      allow create, update, delete: if isAdmin();
    }

    match /hero/{documentId} {
      allow read: if true;
      allow create, update, delete: if isAdmin();
    }

    match /story/{documentId} {
      allow read: if true;
      allow create, update, delete: if isAdmin();
    }

    match /whoAboutSections/{sectionId} {
      allow read: if true;
      allow create, update, delete: if isAdmin();
    }

    match /content/{documentId} {
      allow read: if true;
      allow create, update, delete: if isAdmin();
    }

    // Public can submit contact form; only admins can read/manage
    match /contactSubmissions/{submissionId} {
      allow create: if true;
      allow read, update, delete: if isAdmin();
    }

    // Default deny
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
